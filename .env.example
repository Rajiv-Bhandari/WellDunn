# Neon Postgres connection string (use the pooled URL on Vercel)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-random-string"

# Auth.js URL — leave unset locally; Vercel injects VERCEL_URL automatically.
# Only set this when deploying to a custom domain.
# AUTH_URL="https://your-domain.com"
